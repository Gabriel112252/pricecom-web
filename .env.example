# Base URL da API, embutida no bundle em build-time pelo Vite.
# Em dev: aponta pro Rails local. Em produção (Easypanel): passar como
# --build-arg VITE_API_BASE_URL=https://api.seu-dominio.com/api/v1
# (não como env var de runtime — não tem efeito depois do build).
VITE_API_BASE_URL=http://localhost:3001/api/v1
